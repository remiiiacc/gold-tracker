[Unit]
Description=Gold Tracker API (Flask/Gunicorn)
After=network.target

[Service]
User=root
WorkingDirectory=/opt/gold-tracker/api
Environment="FRED_API_KEY=2b85c4ec0784560d342a8159fa277e7b"
ExecStart=/usr/local/bin/gunicorn -w 2 -b 127.0.0.1:5000 --timeout 120 --access-logfile /opt/gold-tracker/api/access.log --error-logfile /opt/gold-tracker/api/error.log app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
